{
    "Version": "2012-10-17",
    "Id": "S3PolicyDenyPutObjectFromIP",
    "Statement": [
        {
            "Sid": "DenyPutObjectFromSpecificIP",
            "Effect": "Deny",
            "Principal": "*",
            "Action": "s3:PutObject",
            "Resource": "arn:aws:s3:::your-bucket-name/*",
            "Condition": {
                "IpAddress": {
                    "aws:SourceIp": "YOUR_IP_RANGE"
                }
            }
        }
    ]
}
